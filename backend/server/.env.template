# VoiceFlow - Backend Environment Configuration
# Copy this file to backend/.env and fill in your values

# ===== REQUIRED =====
# Get your OpenAI API Key from https://platform.openai.com/api/keys
OPENAI_API_KEY=sk-proj-your-key-here

# ===== OPTIONAL: Workflow Automation =====
# Leave blank to skip Slack integration
SLACK_WEBHOOK_URL=

# Leave blank to skip Discord integration
DISCORD_WEBHOOK_URL=

# ===== DATABASE =====
# SQLite for development (recommended for demo)
DATABASE_URL=sqlite:///./tasks.db

# For production, use PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost/voiceflow

# ===== DEBUG MODE =====
# Set to true for detailed logging during development
DEBUG=false
